{
  "profile": "table_layout_worker",
  "description": "Pruning profile optimized for the post-family table layout specialist. Combines compact layout candidates, key integrity, role signals, relationship evidence, and quality cautions so the worker can propose final table structure and explicit column placement without row-heavy payloads.",
  "artifacts": ["A2", "A5", "A9", "A10", "A12", "A14"],
  "pruning": {
    "A2": {
      "drop": [
        "artifact_inputs",
        "profiler_samples",
        "numeric_profile",
        "datetime_profile"
      ],
      "transforms": {
        "project_a2_layout_grounding": {
          "type": "project_a2_semantic_context_grounding",
          "low_cardinality_max_unique_count": 12,
          "low_cardinality_preview_cap": 20,
          "top_levels_limit": 4,
          "priority_filter_keys": [
            "force_include_columns",
            "skip_trigger_columns"
          ]
        }
      }
    },
    "A5": {
      "drop": [
        "inputs",
        "pair_key_seed_candidates",
        "candidate_key_overlap_groups",
        "audit_trace",
        {
          "key": "rows",
          "scope": "recursive_key_drop",
          "guards": {
            "value_kind_any_of": ["list_of_objects"],
            "path_hints_any_of": [
              "candidate_key_stress_tests[].top_drifted_attributes[].example_conflicts[].rows"
            ]
          },
          "note": "Drop nested example rows from key stress tests; keep only compact drift summaries."
        }
      ],
      "limits": {
        "single_column_key_seed_candidates": 8,
        "candidate_key_stress_tests": 8,
        "candidate_key_stress_tests[].top_drifted_attributes": 2,
        "candidate_key_stress_tests[].top_drifted_attributes[].example_conflicts": 1
      }
    },
    "A9": {
      "drop": [
        "inputs",
        "uses",
        {
          "key": "rows",
          "scope": "recursive_key_drop",
          "guards": {
            "value_kind_any_of": ["list_of_objects"],
            "path_hints_any_of": [
              "row_samples.panels[].rows",
              "example_conflicts[].rows",
              "F_subset.rows"
            ]
          },
          "note": "Mitigation for name-collision risk: only drop when the value looks like row payloads (list of objects) and/or appears under known row-sample containers."
        },
        "evidence_primitives",
        "role_scores",
        "role_candidates",
        "role_decision",
        "audit",
        "evidence_used",
        "evidence_not_used",
        "features"
      ],
      "transforms": {
        "derive_role_candidate_preview": {
          "type": "derive_role_candidate_preview",
          "target_array_path": "columns",
          "output_field": "role_candidate_preview",
          "top_k": 2
        }
      },
      "policies": {
        "columns_policy": {
          "type": "role_bucket_selector",
          "target_array": "columns",
          "role_field": "primary_role",
          "name_field": "column",
          "review_field": "review_required",
          "include_roles_all": [
            {
              "role": "id_key",
              "cap": 12
            },
            {
              "role": "time_index",
              "cap": 8
            },
            {
              "role": "repeat_index",
              "cap": 8
            },
            {
              "role": "invariant_attr",
              "cap": 12
            },
            {
              "role": "coded_categorical",
              "cap": 10
            },
            {
              "role": "measure",
              "cap": 8
            },
            {
              "role": "measure_numeric",
              "cap": 6
            },
            {
              "role": "measure_item",
              "cap": 6
            }
          ],
          "include_review_required_topk": 16,
          "hard_cap_total": 64
        }
      }
    },
    "A10": {
      "drop": [
        "inputs",
        "near_duplicate_candidates",
        "one_hot_blocks",
        "coded_categorical_flags",
        "audit_trail_signals",
        "deterministic_constraints"
      ],
      "limits": {
        "dependency_candidates": 20,
        "time_column_candidates": 10,
        "family_screening_correlations": 10
      }
    },
    "A12": {
      "transforms": {
        "project_a12_table_layout_grounding": {
          "type": "project_a12_table_layout_grounding",
          "preferred_grain_filter_key": "preferred_primary_grain_keys",
          "layout_candidates_top_k": 2,
          "column_placement_preview_cap": 12,
          "ambiguities_cap": 8,
          "family_columns_preview_cap": 8
        }
      },
      "drop": [
        "inputs",
        "evidence_primitives",
        "debug"
      ]
    },
    "A14": {
      "drop": [
        "inputs",
        "segments"
      ],
      "policies": {
        "columns_policy": {
          "type": "column_scope_selector",
          "target_array": "columns",
          "name_field": "column",
          "include_from_filter_keys": [
            "force_include_columns",
            "review_columns",
            "structural_columns"
          ],
          "include_bool_true_fields": [
            "drift_detected"
          ],
          "include_numeric_lte": {
            "global_quality_score": 0.85
          },
          "hard_cap_total": 60
        }
      }
    }
  }
}
