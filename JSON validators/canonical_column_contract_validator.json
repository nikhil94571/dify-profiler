ROW_DEFAULTS = {
    "source_family_id": "",
    "a9_primary_role": "",
    "transform_actions": [],
    "structural_transform_hints": [],
    "interpretation_hints": [],
    "semantic_meaning": "",
    "codebook_note": "",
    "normalization_notes": "",
    "applied_sources": [],
}


def _normalization_repr(value):
    return json.dumps(value, separators=(",", ":"))


def _log_normalization(normalization_log, path, value):
    normalization_log.append({
        "path": path,
        "defaulted_to": _normalization_repr(value),
    })


def _default_in_dict(container, key, value, path, normalization_log):
    if not isinstance(container, dict):
        return
    if key not in container or container[key] is None:
        container[key] = value
        _log_normalization(normalization_log, path, value)


def _add_error(errors, message):
    if message not in errors:
        errors.append(message)


def _require_dict(value, field_name, errors):
    if not isinstance(value, dict):
        _add_error(errors, f"{field_name} must be an object.")
        return False
    return True


def _require_list(value, field_name, errors):
    if not isinstance(value, list):
        _add_error(errors, f"{field_name} must be an array.")
        return False
    return True


def _require_string(value, field_name, errors, allow_blank=False):
    if not isinstance(value, str):
        _add_error(errors, f"{field_name} must be a string.")
        return False
    if not allow_blank and value.strip() == "":
        _add_error(errors, f"{field_name} must not be blank.")
        return False
    return True


def _is_number(value):
    return isinstance(value, (int, float)) and not isinstance(value, bool)


def _normalize_payload(parsed):
    normalization_log = []

    if not isinstance(parsed, dict):
        return parsed, normalization_log

    _default_in_dict(parsed, "global_value_rules", [], "global_value_rules", normalization_log)
    _default_in_dict(parsed, "review_flags", [], "review_flags", normalization_log)
    _default_in_dict(parsed, "assumptions", [], "assumptions", normalization_log)

    summary = parsed.get("summary")
    if isinstance(summary, dict):
        _default_in_dict(summary, "key_contract_principles", [], "summary.key_contract_principles", normalization_log)

    rows = parsed.get("column_contracts")
    if isinstance(rows, list):
        for index, row in enumerate(rows):
            if not isinstance(row, dict):
                continue
            for key, value in ROW_DEFAULTS.items():
                _default_in_dict(row, key, value, f"column_contracts[{index}].{key}", normalization_log)

    return parsed, normalization_log


def _parse_global_token_flag(missingness_worker_json):
    if not isinstance(missingness_worker_json, str) or not missingness_worker_json.strip():
        return None
    try:
        parsed = json.loads(missingness_worker_json)
    except json.JSONDecodeError:
        return None
    if not isinstance(parsed, dict):
        return None
    global_contract = parsed.get("global_contract")
    if not isinstance(global_contract, dict):
        return None
    value = global_contract.get("token_missing_placeholders_detected")
    return value if isinstance(value, bool) else None


def _validate_row_invariants(row, row_prefix, errors, global_token_missing_placeholders_detected=None):
    disposition = row.get("missingness_disposition")
    handling = row.get("missingness_handling")
    decision_source = row.get("missingness_decision_source")
    skip_logic_protected = row.get("skip_logic_protected")

    if row.get("canonical_modeling_status") == "child_repeat_member":
        for hint in row.get("structural_transform_hints") or []:
            if hint in POST_CANONICAL_CHILD_FORBIDDEN_STRUCTURAL_HINTS:
                _add_error(
                    errors,
                    f"{row_prefix}.structural_transform_hints must not contain {hint} when canonical_modeling_status is child_repeat_member",
                )

    allowed_handling = MISSINGNESS_DISPOSITION_TO_ALLOWED_HANDLING.get(disposition)
    if allowed_handling and handling not in allowed_handling:
        _add_error(
            errors,
            f"{row_prefix}.missingness_handling must be one of {sorted(allowed_handling)} when missingness_disposition is {disposition}",
        )

    if handling == "protect_from_null_penalty" and skip_logic_protected is not True:
        _add_error(errors, f"{row_prefix}.skip_logic_protected must be true when missingness_handling is protect_from_null_penalty")

    if skip_logic_protected is True and disposition not in SKIP_LOGIC_TRUE_ALLOWED_DISPOSITIONS:
        _add_error(
            errors,
            f"{row_prefix}.skip_logic_protected can only be true for structurally_valid_missingness or partially_structural_missingness",
        )

    if (
        global_token_missing_placeholders_detected is False
        and disposition == "token_missingness_present"
    ):
        _add_error(
            errors,
            f"{row_prefix}.missingness_disposition must not be token_missingness_present when global_contract.token_missing_placeholders_detected is false",
        )

    if decision_source == "family_default" and disposition not in FAMILY_DEFAULT_ALLOWED_MISSINGNESS_DISPOSITIONS:
        _add_error(
            errors,
            f"{row_prefix}.missingness_decision_source may not be family_default for non-structural missingness_disposition {disposition}",
        )


def _validate_payload(parsed, expected_source_columns, errors, global_token_missing_placeholders_detected=None):
    if not _require_dict(parsed, "canonical_column_contract_json", errors):
        return

    for key in REQUIRED_TOP_LEVEL:
        if key not in parsed:
            _add_error(errors, f"Missing required top-level key: {key}")

    if parsed.get("worker") != "canonical_column_contract_builder":
        _add_error(errors, "worker must be 'canonical_column_contract_builder'")

    summary = parsed.get("summary")
    if _require_dict(summary, "summary", errors):
        for key in SUMMARY_REQUIRED_KEYS:
            if key not in summary:
                _add_error(errors, f"summary.{key} is required")
        if "overview" in summary:
            _require_string(summary["overview"], "summary.overview", errors)
        if "key_contract_principles" in summary and not isinstance(summary["key_contract_principles"], list):
            _add_error(errors, "summary.key_contract_principles must be an array")

    rows = parsed.get("column_contracts")
    if not _require_list(rows, "column_contracts", errors):
        return

    seen_columns = set()
    expected_set = set(expected_source_columns)
    seen_expected = set()

    for index, row in enumerate(rows):
        path = f"column_contracts[{index}]"
        if not _require_dict(row, path, errors):
            continue

        required_row_fields = [
            "column",
            "canonical_modeling_status",
            "canonical_table_name",
            "canonical_assignment_role",
            "source_family_id",
            "a9_primary_role",
            "recommended_logical_type",
            "recommended_storage_type",
            "transform_actions",
            "structural_transform_hints",
            "interpretation_hints",
            "missingness_disposition",
            "missingness_handling",
            "skip_logic_protected",
            "confidence",
            "needs_human_review",
            "type_decision_source",
            "structure_decision_source",
            "missingness_decision_source",
            "semantic_decision_source",
            "applied_sources",
        ]
        for key in required_row_fields:
            if key not in row:
                _add_error(errors, f"{path}.{key} is required")

        column = str(row.get("column") or "").strip()
        if not column:
            _add_error(errors, f"{path}.column must be a non-empty string")
        elif column in seen_columns:
            _add_error(errors, f"Duplicate column_contracts entry for column: {column}")
        else:
            seen_columns.add(column)
            if column in expected_set:
                seen_expected.add(column)

        if row.get("canonical_modeling_status") not in CANONICAL_MODELING_STATUSES:
            _add_error(errors, f"{path}.canonical_modeling_status is invalid")
        if row.get("canonical_assignment_role") not in CANONICAL_ASSIGNMENT_ROLES:
            _add_error(errors, f"{path}.canonical_assignment_role is invalid")
        if row.get("recommended_logical_type") not in TYPE_LOGICAL_TYPES:
            _add_error(errors, f"{path}.recommended_logical_type is invalid")
        if row.get("recommended_storage_type") not in TYPE_STORAGE_TYPES:
            _add_error(errors, f"{path}.recommended_storage_type is invalid")
        if row.get("missingness_disposition") not in MISSINGNESS_DISPOSITIONS:
            _add_error(errors, f"{path}.missingness_disposition is invalid")
        if row.get("missingness_handling") not in MISSINGNESS_HANDLING:
            _add_error(errors, f"{path}.missingness_handling is invalid")
        if row.get("type_decision_source") not in CANONICAL_TYPE_DECISION_SOURCES:
            _add_error(errors, f"{path}.type_decision_source is invalid")
        if row.get("structure_decision_source") not in CANONICAL_STRUCTURE_DECISION_SOURCES:
            _add_error(errors, f"{path}.structure_decision_source is invalid")
        if row.get("missingness_decision_source") not in CANONICAL_MISSINGNESS_DECISION_SOURCES:
            _add_error(errors, f"{path}.missingness_decision_source is invalid")
        if row.get("semantic_decision_source") not in CANONICAL_SEMANTIC_DECISION_SOURCES:
            _add_error(errors, f"{path}.semantic_decision_source is invalid")

        table_name = row.get("canonical_table_name")
        if not isinstance(table_name, str):
            _add_error(errors, f"{path}.canonical_table_name must be a string")
        elif row.get("canonical_assignment_role") in {"exclude_from_outputs", "unresolved"}:
            if table_name.strip():
                _add_error(errors, f"{path}.canonical_table_name must be blank for excluded or unresolved assignments")
        elif table_name.strip() == "":
            _add_error(errors, f"{path}.canonical_table_name must be non-blank for resolved assignments")

        for list_name, allowed in [
            ("transform_actions", TYPE_TRANSFORM_ACTIONS),
            ("structural_transform_hints", TYPE_STRUCTURAL_HINTS),
            ("interpretation_hints", TYPE_INTERPRETATION_HINTS),
        ]:
            values = row.get(list_name)
            if not isinstance(values, list):
                _add_error(errors, f"{path}.{list_name} must be an array")
                continue
            for item_index, item in enumerate(values):
                if not isinstance(item, str) or item not in allowed:
                    _add_error(errors, f"{path}.{list_name}[{item_index}] is invalid")

        if not isinstance(row.get("applied_sources"), list):
            _add_error(errors, f"{path}.applied_sources must be an array")
        else:
            for item_index, item in enumerate(row.get("applied_sources") or []):
                if not isinstance(item, str) or not item.strip():
                    _add_error(errors, f"{path}.applied_sources[{item_index}] is invalid")

        if not isinstance(row.get("skip_logic_protected"), bool):
            _add_error(errors, f"{path}.skip_logic_protected must be boolean")
        if not isinstance(row.get("needs_human_review"), bool):
            _add_error(errors, f"{path}.needs_human_review must be boolean")
        if not _is_number(row.get("confidence")) or not (0.0 <= float(row.get("confidence")) <= 1.0):
            _add_error(errors, f"{path}.confidence must be between 0 and 1")

        _validate_row_invariants(
            row,
            path,
            errors,
            global_token_missing_placeholders_detected=global_token_missing_placeholders_detected,
        )

    missing_expected = sorted(expected_set - seen_expected)
    if missing_expected:
        _add_error(errors, f"column_contracts is missing A2 source columns: {', '.join(missing_expected)}")

    for key in ["global_value_rules", "review_flags", "assumptions"]:
        if not isinstance(parsed.get(key), list):
            _add_error(errors, f"{key} must be an array")


def main(canonical_column_contract_output: str, expected_source_columns_json: str, missingness_worker_json: str = ""):
    output_key = "canonical_column_contract_json"

    if not isinstance(canonical_column_contract_output, str):
        error = "canonical_column_contract_output must be a string."
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps([error], separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    if canonical_column_contract_output.strip() == "":
        error = "canonical_column_contract_output is empty."
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps([error], separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    try:
        parsed = json.loads(canonical_column_contract_output)
    except json.JSONDecodeError as exc:
        error = f"Canonical column contract output is not valid JSON: {exc}"
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps([error], separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    try:
        expected_source_columns = json.loads(expected_source_columns_json)
    except json.JSONDecodeError as exc:
        error = f"expected_source_columns_json is not valid JSON: {exc}"
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps([error], separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    if not isinstance(expected_source_columns, list):
        error = "expected_source_columns_json must decode to an array."
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps([error], separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    parsed, normalization_log = _normalize_payload(parsed)
    normalization_log_json = json.dumps(normalization_log, separators=(",", ":"))
    normalization_applied = "true" if normalization_log else "false"
    global_token_missing_placeholders_detected = _parse_global_token_flag(missingness_worker_json)

    errors = []
    _validate_payload(
        parsed,
        expected_source_columns,
        errors,
        global_token_missing_placeholders_detected=global_token_missing_placeholders_detected,
    )

    if errors:
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": errors[0],
            "validation_errors_json": json.dumps(errors, separators=(",", ":")),
            "normalization_applied": normalization_applied,
            "normalization_log_json": normalization_log_json,
        }

    return {
        "validation_ok": "true",
        output_key: json.dumps(parsed, separators=(",", ":")),
        "validation_error": "",
        "validation_errors_json": "[]",
        "normalization_applied": normalization_applied,
        "normalization_log_json": normalization_log_json,
    }
