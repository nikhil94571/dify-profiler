def _normalization_repr(value):
    return json.dumps(value, separators=(",", ":"))


def _log_normalization(normalization_log, path, value):
    normalization_log.append({
        "path": path,
        "defaulted_to": _normalization_repr(value),
    })


def _default_in_dict(container, key, value, path, normalization_log):
    if not isinstance(container, dict):
        return
    if key not in container or container[key] is None:
        container[key] = value
        _log_normalization(normalization_log, path, value)


def _add_error(errors, message):
    if message not in errors:
        errors.append(message)


def _require_obj(value, field_name, errors):
    if not isinstance(value, dict):
        _add_error(errors, f"{field_name} must be an object.")
        return False
    return True


def _require_list(value, field_name, errors):
    if not isinstance(value, list):
        _add_error(errors, f"{field_name} must be an array.")
        return False
    return True


def _require_str(value, field_name, errors, allow_blank=False):
    if not isinstance(value, str):
        _add_error(errors, f"{field_name} must be a string.")
        return False
    if not allow_blank and value.strip() == "":
        _add_error(errors, f"{field_name} must not be blank.")
        return False
    return True


def _require_bool(value, field_name, errors):
    if not isinstance(value, bool):
        _add_error(errors, f"{field_name} must be a boolean.")
        return False
    return True


def _require_string_list(value, field_name, errors, allow_blank_items=False):
    if not _require_list(value, field_name, errors):
        return False
    ok = True
    for i, item in enumerate(value):
        if not _require_str(item, f"{field_name}[{i}]", errors, allow_blank=allow_blank_items):
            ok = False
    return ok


def _is_number(value):
    return isinstance(value, (int, float)) and not isinstance(value, bool)


def _parse_json_object(raw_value, field_name):
    if not isinstance(raw_value, str):
        return None, [f"{field_name} must be a string."]
    if raw_value.strip() == "":
        return None, [f"{field_name} is empty."]
    try:
        parsed = json.loads(raw_value)
    except json.JSONDecodeError as exc:
        return None, [f"{field_name} is not valid JSON: {exc}"]
    if not isinstance(parsed, dict):
        return None, [f"{field_name} root must be an object."]
    return parsed, []


def _normalize_patch_output(parsed):
    normalization_log = []

    if not isinstance(parsed, dict):
        return parsed, normalization_log

    review_summary = parsed.get("review_summary")
    if isinstance(review_summary, dict):
        _default_in_dict(
            review_summary,
            "review_principles",
            [],
            "review_summary.review_principles",
            normalization_log,
        )

    _default_in_dict(parsed, "change_set", [], "change_set", normalization_log)
    _default_in_dict(parsed, "review_flags", [], "review_flags", normalization_log)
    _default_in_dict(parsed, "assumptions", [], "assumptions", normalization_log)

    return parsed, normalization_log


def _normalize_noop_change_entries(parsed, original_contract, normalization_log):
    if not isinstance(parsed, dict):
        return parsed

    change_set = parsed.get("change_set")
    rows = original_contract.get("column_contracts")
    if not isinstance(change_set, list) or not isinstance(rows, list):
        return parsed

    column_index_map = {}
    for row_index, row in enumerate(rows):
        if not isinstance(row, dict):
            continue
        column = str(row.get("column") or "").strip()
        if column and column not in column_index_map:
            column_index_map[column] = row_index

    normalized_change_set = []
    for index, item in enumerate(change_set):
        if not isinstance(item, dict):
            normalized_change_set.append(item)
            continue
        column_name = str(item.get("column") or "").strip()
        field_name = str(item.get("field") or "").strip()
        row_index = column_index_map.get(column_name)
        if (
            row_index is not None
            and field_name in PATCHABLE_FIELDS
            and isinstance(rows[row_index], dict)
            and field_name in rows[row_index]
            and rows[row_index].get(field_name) == item.get("after_value")
        ):
            _log_normalization(
                normalization_log,
                f"change_set[{index}]",
                {"removed": "no_op_change_entry"},
            )
            continue
        normalized_change_set.append(item)

    parsed["change_set"] = normalized_change_set
    return parsed


def _validate_review_summary(review_summary, errors):
    if not _require_obj(review_summary, "review_summary", errors):
        return

    extra = set(review_summary.keys()) - set(REVIEW_SUMMARY_REQUIRED)
    if extra:
        _add_error(errors, f"review_summary has unexpected key(s): {', '.join(sorted(extra))}")

    for key in REVIEW_SUMMARY_REQUIRED:
        if key not in review_summary:
            _add_error(errors, f"review_summary.{key} is required.")

    if "overview" in review_summary:
        _require_str(review_summary["overview"], "review_summary.overview", errors)
    if "review_principles" in review_summary:
        _require_string_list(
            review_summary["review_principles"],
            "review_summary.review_principles",
            errors,
            allow_blank_items=False,
        )


def _validate_review_flags(review_flags, errors):
    if not _require_list(review_flags, "review_flags", errors):
        return
    for i, item in enumerate(review_flags):
        path = f"review_flags[{i}]"
        if not _require_obj(item, path, errors):
            continue
        for key in ["item", "issue", "why"]:
            if key not in item:
                _add_error(errors, f"{path}.{key} is required.")
            else:
                _require_str(item[key], f"{path}.{key}", errors)


def _validate_assumptions(assumptions, errors):
    if not _require_list(assumptions, "assumptions", errors):
        return
    for i, item in enumerate(assumptions):
        path = f"assumptions[{i}]"
        if not _require_obj(item, path, errors):
            continue
        for key in ["assumption", "explanation"]:
            if key not in item:
                _add_error(errors, f"{path}.{key} is required.")
            else:
                _require_str(item[key], f"{path}.{key}", errors)


def _build_column_index_map(rows, errors, path_prefix):
    index_map = {}
    for index, row in enumerate(rows):
        if not isinstance(row, dict):
            continue
        column = str(row.get("column") or "").strip()
        if not column:
            continue
        if column in index_map:
            _add_error(errors, f"{path_prefix} has duplicate column entries for {column}.")
            continue
        index_map[column] = index
    return index_map


def _validate_original_contract(original_contract, errors):
    if not _require_obj(original_contract, "canon_contract_json", errors):
        return

    if original_contract.get("worker") != "canonical_column_contract_builder":
        _add_error(errors, "canon_contract_json.worker must be 'canonical_column_contract_builder'.")

    summary = original_contract.get("summary")
    if not isinstance(summary, dict):
        _add_error(errors, "canon_contract_json.summary must be an object.")

    rows = original_contract.get("column_contracts")
    if not isinstance(rows, list) or len(rows) == 0:
        _add_error(errors, "canon_contract_json.column_contracts must be a non-empty array.")
        return

    seen_columns = set()
    for index, row in enumerate(rows):
        path = f"canon_contract_json.column_contracts[{index}]"
        if not isinstance(row, dict):
            _add_error(errors, f"{path} must be an object.")
            continue
        if "column" not in row or not isinstance(row.get("column"), str) or row.get("column", "").strip() == "":
            _add_error(errors, f"{path}.column must be a non-empty string.")
            continue
        column = row["column"].strip()
        if column in seen_columns:
            _add_error(errors, f"canon_contract_json.column_contracts has duplicate column entries for {column}.")
            continue
        seen_columns.add(column)
        _validate_row_coherence(row, path, errors)


def _validate_field_value(field_name, value, errors, field_prefix):
    if field_name in STRING_ENUM_FIELDS:
        if _require_str(value, field_prefix, errors):
            if value not in STRING_ENUM_FIELDS[field_name]:
                _add_error(errors, f"{field_prefix} is invalid.")
        return

    if field_name in LIST_ENUM_FIELDS:
        if _require_list(value, field_prefix, errors):
            for i, item in enumerate(value):
                if not _require_str(item, f"{field_prefix}[{i}]", errors):
                    continue
                if item not in LIST_ENUM_FIELDS[field_name]:
                    _add_error(errors, f"{field_prefix}[{i}] is invalid.")
        return

    if field_name == "applied_sources":
        _require_string_list(value, field_prefix, errors, allow_blank_items=False)
        return

    if field_name in STRING_FIELDS:
        _require_str(value, field_prefix, errors, allow_blank=True)
        return

    if field_name in BOOL_FIELDS:
        _require_bool(value, field_prefix, errors)
        return

    if field_name in NUMERIC_FIELDS:
        if not _is_number(value):
            _add_error(errors, f"{field_prefix} must be numeric.")
        elif not (0 <= float(value) <= 1):
            _add_error(errors, f"{field_prefix} must be between 0 and 1.")
        return

    _add_error(errors, f"{field_prefix} targets an unsupported field.")


def _validate_row_coherence(row, row_prefix, errors):
    if row.get("canonical_modeling_status") not in CANONICAL_MODELING_STATUSES:
        _add_error(errors, f"{row_prefix}.canonical_modeling_status is invalid.")

    assignment_role = row.get("canonical_assignment_role")
    if assignment_role not in CANONICAL_ASSIGNMENT_ROLES:
        _add_error(errors, f"{row_prefix}.canonical_assignment_role is invalid.")

    table_name = row.get("canonical_table_name")
    if not isinstance(table_name, str):
        _add_error(errors, f"{row_prefix}.canonical_table_name must be a string.")
    else:
        if assignment_role in {"exclude_from_outputs", "unresolved"} and table_name.strip() != "":
            _add_error(errors, f"{row_prefix}.canonical_table_name must be blank for excluded or unresolved rows.")
        if assignment_role not in {"exclude_from_outputs", "unresolved"} and table_name.strip() == "":
            _add_error(errors, f"{row_prefix}.canonical_table_name must not be blank for resolved rows.")

    for field_name, allowed in [
        ("recommended_logical_type", TYPE_LOGICAL_TYPES),
        ("recommended_storage_type", TYPE_STORAGE_TYPES),
        ("missingness_disposition", MISSINGNESS_DISPOSITIONS),
        ("missingness_handling", MISSINGNESS_HANDLING),
        ("type_decision_source", TYPE_DECISION_SOURCES),
        ("structure_decision_source", STRUCTURE_DECISION_SOURCES),
        ("missingness_decision_source", MISSINGNESS_DECISION_SOURCES),
        ("semantic_decision_source", SEMANTIC_DECISION_SOURCES),
    ]:
        if row.get(field_name) not in allowed:
            _add_error(errors, f"{row_prefix}.{field_name} is invalid.")

    if not isinstance(row.get("skip_logic_protected"), bool):
        _add_error(errors, f"{row_prefix}.skip_logic_protected must be a boolean.")
    if not isinstance(row.get("needs_human_review"), bool):
        _add_error(errors, f"{row_prefix}.needs_human_review must be a boolean.")
    if not _is_number(row.get("confidence")) or not (0 <= float(row.get("confidence")) <= 1):
        _add_error(errors, f"{row_prefix}.confidence must be between 0 and 1.")

    for list_name, allowed in [
        ("transform_actions", TYPE_TRANSFORM_ACTIONS),
        ("structural_transform_hints", TYPE_STRUCTURAL_HINTS),
        ("interpretation_hints", TYPE_INTERPRETATION_HINTS),
    ]:
        values = row.get(list_name)
        if not isinstance(values, list):
            _add_error(errors, f"{row_prefix}.{list_name} must be an array.")
            continue
        for i, item in enumerate(values):
            if not isinstance(item, str) or item not in allowed:
                _add_error(errors, f"{row_prefix}.{list_name}[{i}] is invalid.")
            elif (
                list_name == "structural_transform_hints"
                and row.get("canonical_modeling_status") == "child_repeat_member"
                and item in POST_CANONICAL_CHILD_FORBIDDEN_STRUCTURAL_HINTS
            ):
                _add_error(
                    errors,
                    f"{row_prefix}.structural_transform_hints must not contain {item} when canonical_modeling_status is child_repeat_member.",
                )

    applied_sources = row.get("applied_sources")
    if not isinstance(applied_sources, list):
        _add_error(errors, f"{row_prefix}.applied_sources must be an array.")
    else:
        for i, item in enumerate(applied_sources):
            if not isinstance(item, str) or item.strip() == "":
                _add_error(errors, f"{row_prefix}.applied_sources[{i}] is invalid.")

    if row.get("missingness_handling") == "protect_from_null_penalty" and row.get("skip_logic_protected") is not True:
        _add_error(errors, f"{row_prefix}.skip_logic_protected must be true when missingness_handling is protect_from_null_penalty.")

    disposition = row.get("missingness_disposition")
    handling = row.get("missingness_handling")
    allowed_handling = MISSINGNESS_DISPOSITION_TO_ALLOWED_HANDLING.get(disposition)
    if allowed_handling and handling not in allowed_handling:
        _add_error(
            errors,
            f"{row_prefix}.missingness_handling must be one of {sorted(allowed_handling)} when missingness_disposition is {disposition}.",
        )

    if row.get("skip_logic_protected") is True and disposition not in SKIP_LOGIC_TRUE_ALLOWED_DISPOSITIONS:
        _add_error(
            errors,
            f"{row_prefix}.skip_logic_protected can only be true for structurally_valid_missingness or partially_structural_missingness.",
        )

    if (
        row.get("missingness_decision_source") == "family_default"
        and disposition not in FAMILY_DEFAULT_ALLOWED_MISSINGNESS_DISPOSITIONS
    ):
        _add_error(
            errors,
            f"{row_prefix}.missingness_decision_source may not be family_default for non-structural missingness_disposition {disposition}.",
        )


def _validate_change_set(change_set, original_contract, errors):
    if not _require_list(change_set, "change_set", errors):
        return

    rows = original_contract.get("column_contracts") or []
    preview_contract = copy.deepcopy(original_contract)
    column_index_map = _build_column_index_map(rows, errors, "canon_contract_json.column_contracts")
    seen_change_ids = set()
    seen_column_fields = set()
    touched_row_indices = set()

    for index, item in enumerate(change_set):
        path = f"change_set[{index}]"
        if not _require_obj(item, path, errors):
            continue

        extra_keys = set(item.keys()) - set(PATCH_ENTRY_REQUIRED)
        if extra_keys:
            _add_error(errors, f"{path} has unexpected key(s): {', '.join(sorted(extra_keys))}")

        for key in PATCH_ENTRY_REQUIRED:
            if key not in item:
                _add_error(errors, f"{path}.{key} is required.")

        change_id_ok = "change_id" in item and _require_str(item.get("change_id"), f"{path}.change_id", errors)
        if change_id_ok:
            if item["change_id"] in seen_change_ids:
                _add_error(errors, f"Duplicate change_set.change_id: {item['change_id']}")
            else:
                seen_change_ids.add(item["change_id"])

        column_ok = "column" in item and _require_str(item.get("column"), f"{path}.column", errors)
        field_ok = "field" in item and _require_str(item.get("field"), f"{path}.field", errors)

        if "reasoning" in item:
            _require_str(item["reasoning"], f"{path}.reasoning", errors)
        if "justification" in item:
            _require_str(item["justification"], f"{path}.justification", errors)
        if "confidence" in item:
            if not _is_number(item["confidence"]):
                _add_error(errors, f"{path}.confidence must be numeric.")
            elif not (0 <= float(item["confidence"]) <= 1):
                _add_error(errors, f"{path}.confidence must be between 0 and 1.")
        if "needs_human_review" in item:
            _require_bool(item["needs_human_review"], f"{path}.needs_human_review", errors)

        if not column_ok or not field_ok:
            continue

        column_name = item["column"]
        field_name = item["field"]
        if field_name not in PATCHABLE_FIELDS:
            _add_error(errors, f"{path}.field points to a forbidden field: {field_name}")
            continue

        row_index = column_index_map.get(column_name)
        if row_index is None:
            _add_error(errors, f"{path}.column does not exist in canon_contract_json: {column_name}")
            continue

        row = rows[row_index]
        if not isinstance(row, dict):
            _add_error(errors, f"canon_contract_json.column_contracts[{row_index}] must be an object.")
            continue

        if field_name not in row:
            _add_error(errors, f"{path}.field does not exist in canon_contract_json.column_contracts[{row_index}]: {field_name}")
            continue

        pair = (column_name, field_name)
        if pair in seen_column_fields:
            _add_error(errors, f"Duplicate change_set column/field pair: {column_name}.{field_name}")
            continue
        seen_column_fields.add(pair)

        before_error_count = len(errors)
        _validate_field_value(field_name, item.get("after_value"), errors, f"{path}.after_value")
        if len(errors) != before_error_count:
            continue

        if field_name == "interpretation_hints":
            before_has_skip_hint = "skip_logic_protected" in (row.get("interpretation_hints") or [])
            after_has_skip_hint = "skip_logic_protected" in (item.get("after_value") or [])
            if before_has_skip_hint != after_has_skip_hint:
                _add_error(
                    errors,
                    f"{path}.field cannot add or remove skip_logic_protected in interpretation_hints because that bookkeeping is code-owned.",
                )
                continue

        preview_contract["column_contracts"][row_index][field_name] = item["after_value"]
        touched_row_indices.add(row_index)

    for row_index in sorted(touched_row_indices):
        preview_row = preview_contract["column_contracts"][row_index]
        _validate_row_coherence(
            preview_row,
            f"preview_contract.column_contracts[{row_index}]",
            errors,
        )


def _validate_strict(reviewer_output: str, canon_contract_json: str):
    output_key = "canon_review_patch"

    patch_output, parse_errors = _parse_json_object(reviewer_output, "reviewer_output")
    if parse_errors:
        error = parse_errors[0]
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps(parse_errors, separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    original_contract, original_errors = _parse_json_object(canon_contract_json, "canon_contract_json")
    if original_errors:
        error = original_errors[0]
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": error,
            "validation_errors_json": json.dumps(original_errors, separators=(",", ":")),
            "normalization_applied": "false",
            "normalization_log_json": "[]",
        }

    patch_output, normalization_log = _normalize_patch_output(patch_output)
    normalization_log_json = json.dumps(normalization_log, separators=(",", ":"))
    normalization_applied = "true" if normalization_log else "false"

    errors = []

    _validate_original_contract(original_contract, errors)
    if errors:
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": errors[0],
            "validation_errors_json": json.dumps(errors, separators=(",", ":")),
            "normalization_applied": normalization_applied,
            "normalization_log_json": normalization_log_json,
        }

    patch_output = _normalize_noop_change_entries(patch_output, original_contract, normalization_log)
    normalization_log_json = json.dumps(normalization_log, separators=(",", ":"))
    normalization_applied = "true" if normalization_log else "false"

    extra_keys = set(patch_output.keys()) - set(REQUIRED_TOP_LEVEL)
    if extra_keys:
        _add_error(errors, f"Unexpected top-level key(s): {', '.join(sorted(extra_keys))}")

    for key in REQUIRED_TOP_LEVEL:
        if key not in patch_output:
            _add_error(errors, f"Missing required top-level key: {key}")

    if "worker" in patch_output and _require_str(patch_output.get("worker"), "worker", errors):
        if patch_output["worker"] != "canonical_contract_reviewer":
            _add_error(errors, "worker must be 'canonical_contract_reviewer'.")

    if "review_summary" in patch_output:
        _validate_review_summary(patch_output["review_summary"], errors)
    if "change_set" in patch_output:
        _validate_change_set(patch_output["change_set"], original_contract, errors)
    if "review_flags" in patch_output:
        _validate_review_flags(patch_output["review_flags"], errors)
    if "assumptions" in patch_output:
        _validate_assumptions(patch_output["assumptions"], errors)

    if errors:
        return {
            "validation_ok": "false",
            output_key: "",
            "validation_error": errors[0],
            "validation_errors_json": json.dumps(errors, separators=(",", ":")),
            "normalization_applied": normalization_applied,
            "normalization_log_json": normalization_log_json,
        }

    return {
        "validation_ok": "true",
        output_key: json.dumps(patch_output, separators=(",", ":")),
        "validation_error": "",
        "validation_errors_json": "[]",
        "normalization_applied": normalization_applied,
        "normalization_log_json": normalization_log_json,
    }


def main(reviewer_output: str, canon_contract_json: str):
    return _validate_strict(reviewer_output, canon_contract_json)
